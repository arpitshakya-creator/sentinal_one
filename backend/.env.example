# ---------------------------------------------------------------------------
# Backend server
# ---------------------------------------------------------------------------
PORT=4000

# ---------------------------------------------------------------------------
# AI agents (Risk Intelligence, Impact Simulation, Mitigation)
# The platform fully works without AI (deterministic engine); these settings
# enable the LLM-generated executive narrative summaries.
# ---------------------------------------------------------------------------

# Provider: "openai" (default — OpenAI-compatible gateway) | "anthropic" | "bedrock"
AI_PROVIDER=openai

# Portal virtual key (the team's sk-... key).
AI_API_KEY=

# Base URL of the OpenAI-compatible gateway/portal. REQUIRED in openai mode.
# Example shape: https://<portal-host>/v1
AI_BASE_URL=

# Model id (GPT-4 family recommended for the hackathon).
AI_MODEL=gpt-4o

# --- Direct Amazon Bedrock (only when AI_PROVIDER=bedrock) ---
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AI_MODEL=anthropic.claude-opus-4-8

# ---------------------------------------------------------------------------
# Threat intelligence
# ---------------------------------------------------------------------------
# Optional: NVD API key for higher rate limits (50 req/30s instead of 5 req/30s).
# Get a free key at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
