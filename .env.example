# Anthropic Claude API key — enables AI agent narrative summaries.
# The platform fully works without it (deterministic engine), but set this to
# activate the Risk Intelligence, Impact Simulation, and Mitigation AI agents.
ANTHROPIC_API_KEY=""

# Optional: NVD API key for higher rate limits (50 req/30s instead of 5 req/30s).
# Get a free key at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Claude model used for agent calls.
ANTHROPIC_MODEL=claude-sonnet-4-20250514
